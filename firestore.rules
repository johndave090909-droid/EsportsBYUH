rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // An officer is any signed-in user whose email exists as a document ID
    // in the "officers" collection (IDs are stored lowercased).
    function isOfficer() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(db)/documents/officers/$(request.auth.token.email.lower()));
    }

    // Officer allowlist: readable by any signed-in user (so the login flow
    // can check membership), writable only by officers.
    match /officers/{email} {
      allow read: if request.auth != null;
      allow write: if isOfficer();
    }

    // Officer chat room (admin panel only): officers read, post as
    // themselves, and delete.
    match /chat/{mid} {
      allow read: if isOfficer();
      allow create: if isOfficer()
        && request.resource.data.email == request.auth.token.email.lower()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500;
      allow delete: if isOfficer();
    }

    // Officer inbox: a thread is visible only to its two participants,
    // and both sides must be officers.
    match /threads/{tid} {
      allow read: if isOfficer()
        && request.auth.token.email.lower() in resource.data.participants;
      allow create: if isOfficer()
        && request.auth.token.email.lower() in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isOfficer()
        && request.auth.token.email.lower() in resource.data.participants
        && request.resource.data.participants == resource.data.participants;

      match /messages/{mid} {
        allow read: if isOfficer()
          && request.auth.token.email.lower() in get(/databases/$(db)/documents/threads/$(tid)).data.participants;
        allow create: if isOfficer()
          && request.auth.token.email.lower() in get(/databases/$(db)/documents/threads/$(tid)).data.participants
          && request.resource.data.from == request.auth.token.email.lower()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
      }
    }

    // Public site content: anyone can read, only officers can write.
    match /settings/{doc} { allow read: if true; allow write: if isOfficer(); }
    match /matches/{doc}  { allow read: if true; allow write: if isOfficer(); }
    match /news/{doc}     { allow read: if true; allow write: if isOfficer(); }
    match /photos/{doc}   { allow read: if true; allow write: if isOfficer(); }
    match /videos/{doc}   { allow read: if true; allow write: if isOfficer(); }
  }
}
